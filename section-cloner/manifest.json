{
  "manifest_version": 3,
  "name": "2urn · Carrd Section Cloner",
  "version": "1.0.0",
  "description": "Clone entire Carrd sections (scrollpoint + all containers) with one click.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["*://app.carrd.co/*"],
  "content_scripts": [
    {
      "matches": ["*://app.carrd.co/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
